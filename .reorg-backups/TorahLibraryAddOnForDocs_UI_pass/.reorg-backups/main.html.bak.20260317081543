<!DOCTYPE html>
  <head>
    <base target="_top">

    <!--STYLESHEETS-->
    <link rel="stylesheet" href="https://ssl.gstatic.com/docs/script/css/add-ons.css">
    <link rel="stylesheet" href="//ajax.googleapis.com/ajax/libs/jqueryui/1.9.1/themes/smoothness/jquery-ui.css" />

    <style>
    /* note: no need to really make the layout responsive any more than vw and vh usage, due to the constraints of Google Add-ons.*/
    :root {
      --bg: #f5f5f3;
      --panel: #ffffff;
      --card: #e9e7e3;
      --border: #d4d0ca;
      --text: #222222;
      --muted: #6b6b6b;
      --selected: #1f3b68;
      --selected-hover: #29497d;
      --selected-soft: #c9d5e8;
    }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
    }

    .ui-autocomplete {
      width: 240px !important;
      overflow-y: scroll;
    }

    [class=hide] > img {
      position: absolute;
      top: 48%; 
      left: 48%;
    }

    main {
      margin: 0;
      min-height: 100vh;
      overflow:auto;
      padding: 12px;
      box-sizing: border-box;
    }

    aside {
      display: none; 
      position: absolute; 
      top: 0; 
      left: 0; 
      width: 100%; 
      height: 100%; 
      color: black; 
      background: white; 
      z-index: 5;
    }

    .reference-row {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .search-control-row {
      margin-top: 8px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px;
      align-items: center;
    }

    .search-filter-select {
      width: 100%;
      box-sizing: border-box;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #fff;
      background-image: none !important;
      padding: 8px 10px;
      font-size: 13px;
      min-height: 36px;
      appearance: none;
      -webkit-appearance: none;
      -moz-appearance: none;
    }

    .search-filter-select:hover,
    .search-filter-select:focus {
      background: #fff;
      border-color: var(--selected);
    }

    .relevance-toggle {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: #444;
      white-space: nowrap;
      user-select: none;
    }

    #run-sefaria,
    #insert-source {
      border: 0;
      border-radius: 10px;
      background: var(--selected);
      color: #fff;
      padding: 10px 12px;
      min-height: 42px;
      font-size: 13px;
      font-weight: 600;
      width: auto !important;
      margin: 0;
      align-self: center;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    #run-sefaria:disabled,
    #insert-source:disabled {
      opacity: 0.5;
    }

    #run-sefaria:not(:disabled):hover,
    #insert-source:not(:disabled):hover {
      background: var(--selected-hover);
    }

    #insert-source {
      margin-top: 12px;
      width: 100%;
    }

    /* extremely ungainly usage of !important, need to fix at some point */
    .input {
      margin: 0 !important;
      display: block !important;
      width: 100% !important;
      height: auto !important;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #fff;
      padding: 10px 12px;
      font-size: 14px;
      box-sizing: border-box;
    }

    .reference-input-shell {
      flex: 1;
      min-width: 0;
    }

    .section-label {
      margin: 14px 0 8px;
      font-size: 13px;
      font-weight: 600;
      color: #444;
    }

    .mode-card-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .mode-card {
      border: 1px solid transparent;
      border-radius: 12px;
      background: var(--card);
      color: var(--text);
      padding: 12px 14px;
      text-align: left;
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      cursor: pointer;
      font-size: 14px;
    }

    .mode-card > span:first-child {
      flex: 1;
      text-align: left;
      margin-right: 10px;
    }

    .mode-card:hover {
      border-color: var(--border);
    }

    .mode-card.selected {
      background: var(--selected);
      color: #fff;
    }

    .mode-card:focus-visible,
    .layout-option:focus-visible {
      outline: 2px solid var(--selected);
      outline-offset: 2px;
    }

    .mode-card-indicator {
      width: 16px;
      height: 16px;
      border-radius: 999px;
      border: 2px solid currentColor;
      box-sizing: border-box;
    }

    .mode-card.selected .mode-card-indicator {
      background: currentColor;
      box-shadow: inset 0 0 0 3px var(--selected);
    }

    .layout-option-group {
      display: flex;
      gap: 8px;
    }

    .layout-option {
      width: 50px;
      height: 48px;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #fff;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .layout-option.selected {
      border-color: var(--selected);
      box-shadow: inset 0 0 0 1px var(--selected);
      background: var(--selected-soft);
    }

    .layout-icon {
      position: relative;
      width: 26px;
      height: 20px;
      border: 1px solid #bcb8b1;
      border-radius: 4px;
      background: #f7f7f5;
    }

    .layout-icon::before,
    .layout-icon::after {
      content: '';
      position: absolute;
      background: #b3b0aa;
    }

    .layout-icon-top::before {
      height: 7px;
      width: 100%;
      top: 1px;
      left: 0;
      background: #7f97bb;
    }

    .layout-icon-top::after {
      height: 7px;
      width: 100%;
      left: 0;
      bottom: 1px;
    }

    .layout-icon-left::before,
    .layout-icon-right::before {
      top: 0;
      width: 11px;
      height: 100%;
      left: 0;
    }

    .layout-icon-left::after,
    .layout-icon-right::after {
      top: 0;
      width: 11px;
      height: 100%;
      right: 0;
    }

    .layout-icon-left::before {
      background: #7f97bb;
    }

    .layout-icon-right::after {
      background: #7f97bb;
    }

    .options-panel,
    .versions-panel,
    .preview-panel {
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--panel);
      padding: 10px;
    }

    .toggle-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }

    .toggle-row + .toggle-row {
      margin-top: 10px;
    }

    .helper-text {
      margin: 4px 0 0;
      font-size: 11px;
      color: var(--muted);
    }

    .version-control + .version-control {
      margin-top: 10px;
    }

    .version-control-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 8px;
      margin-bottom: 6px;
    }

    .version-count {
      font-size: 11px;
      color: var(--muted);
    }

    .version-label {
      display: block;
      margin-bottom: 4px;
      font-size: 12px;
      font-weight: 600;
      color: #555;
    }

    .versioning-select,
    .translation-filter-input,
    .translation-version-select {
      width: 100%;
      box-sizing: border-box;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #fff;
      padding: 8px 10px;
      font-size: 14px;
      min-height: 38px;
      line-height: 1.3;
    }


    .suggestions {
      margin: 0;
      min-height: 150px;
      max-height: 46vh;
      overflow: auto;
      font-size: 14px;
      line-height: 1.45;
      color: var(--text);
    }

    .results-panel {
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--panel);
      padding: 10px;
      margin-top: 12px;
    }

    .result-group-label {
      margin: 0 0 6px;
      font-size: 12px;
      color: #555;
      font-weight: 600;
    }

    .result-list {
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .result-list + .result-group-label {
      margin-top: 10px;
    }

    .result-item {
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #fff;
      padding: 8px 10px;
      cursor: pointer;
      width: 100%;
      text-align: left;
      margin-bottom: 6px;
      display: block;
      box-sizing: border-box;
    }

    .result-item.selected {
      border-color: var(--selected);
      background: var(--selected-soft);
      box-shadow: inset 0 0 0 1px var(--selected);
    }

    .result-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 2px;
      overflow-wrap: anywhere;
    }

    .result-type {
      display: inline-block;
      margin-bottom: 4px;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #5d6878;
      font-weight: 700;
    }

    .result-subtitle,
    .result-snippet {
      font-size: 12px;
      color: var(--muted);
      overflow-wrap: anywhere;
    }

    .preview-table {
      width: 100%;
      border-collapse: collapse;
    }

    .preview-table td {
      vertical-align: top;
      width: 50%;
      padding: 0 6px 8px;
    }

    .preview-meta {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 6px;
      overflow-wrap: anywhere;
    }

    .preview-he {
      direction: rtl;
    }

    .branding-text {
      padding-top: 0.5em;
    }

    .translation-version-select {
      margin-top: 6px;
      min-height: 150px;
      padding: 4px;
    }

    .translation-version-select option {
      text-indent: 0;
      padding-left: 0;
      margin-left: 0;
    }

    .translation-selected-display {
      margin-top: 6px;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: #fff;
      padding: 6px 8px;
      font-size: 12px;
      line-height: 1.4;
      max-height: 88px;
      overflow: auto;
      white-space: normal;
      word-break: break-word;
    }

    .preview-refresh-status {
      margin: 6px 0 0;
      font-size: 12px;
      color: var(--muted);
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .preview-refresh-status::before {
      content: '';
      width: 10px;
      height: 10px;
      border: 2px solid #d2d7df;
      border-top-color: #5672a5;
      border-radius: 50%;
      animation: preview-spin 0.8s linear infinite;
    }

    @keyframes preview-spin {
      to {
        transform: rotate(360deg);
      }
    }

    .advanced-version-details {
      margin-top: 10px;
      border-top: 1px solid var(--border);
      padding-top: 8px;
      opacity: 0.9;
    }

    .advanced-version-details summary {
      font-size: 12px;
      font-weight: 600;
      color: #555;
      cursor: pointer;
      list-style: none;
    }

    .advanced-version-note {
      margin: 6px 0 0;
      font-size: 11px;
      color: var(--muted);
    }

    .section-muted {
      opacity: 0.55;
    }

    .noninsertable-warning {
      border: 1px solid #e7c97a;
      background: #fff7e0;
      border-radius: 10px;
      padding: 10px 12px;
      margin-top: 4px;
    }

    .noninsertable-warning .preview-state-title {
      color: #6a4d00;
      margin-bottom: 4px;
    }

    .insert-warning {
      border: 1px solid #d93025;
      background: #fdecea;
      border-radius: 10px;
      padding: 10px 12px;
      margin-bottom: 8px;
      color: #8d1f1a;
      font-size: 12px;
      font-weight: 700;
      line-height: 1.45;
    }

    .advanced-version-details summary::-webkit-details-marker {
      display: none;
    }

    .advanced-version-details summary::before {
      content: '▸';
      margin-right: 6px;
      color: #666;
    }

    .advanced-version-details[open] summary::before {
      content: '▾';
    }

    .results-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
    }

    .results-toggle-button {
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #fff;
      color: var(--selected);
      padding: 6px 10px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
    }

    .selected-result-summary {
      margin-bottom: 8px;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #fff;
      padding: 8px 10px;
      font-size: 12px;
      color: #444;
    }

    .selected-result-summary strong {
      display: block;
      font-size: 13px;
      color: var(--text);
      margin-bottom: 2px;
      overflow-wrap: anywhere;
    }

    .results-hint {
      margin: 8px 0 0;
      font-size: 12px;
      color: var(--muted);
      display: none;
    }

    .preview-state-title {
      margin: 0 0 6px;
      font-size: 14px;
      font-weight: 600;
    }

    .preview-state-message {
      margin: 0;
      font-size: 12px;
      color: var(--muted);
      line-height: 1.5;
    }

    .visually-hidden {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      border: 0;
    }

    </style>

    <!--SCRIPTS-->
    <script src="//ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js"></script>
    <script src="//ajax.googleapis.com/ajax/libs/jqueryui/1.9.1/jquery-ui.min.js"></script>

  </head>
  <body>
    <main>

      <aside class="hide">
        <img src="https://www.sefaria.org/static/img/ajax-loader.gif">
      </aside>

      <div class="section-label">Find a source</div>
      <section class="reference-row">
        <div class="reference-input-shell">
          <input type="text" class="input disab" placeholder="Reference, title, or phrase" aria-label="Find a source">
        </div>
        <button class="search-submit" id="run-sefaria">Find</button>
      </section>
      <section class="search-control-row" aria-label="Search controls">
        <select class="search-filter-select" aria-label="Corpus filter">
          <option value="" selected>Corpus: All</option>
          <option value="Tanakh">Corpus: Tanakh</option>
          <option value="Mishnah">Corpus: Mishnah</option>
          <option value="Talmud">Corpus: Talmud</option>
          <option value="Halakhah">Corpus: Halakhah</option>
          <option value="Midrash">Corpus: Midrash</option>
          <option value="Kabbalah">Corpus: Kabbalah</option>
          <option value="Liturgy">Corpus: Liturgy</option>
          <option value="Philosophy">Corpus: Philosophy</option>
          <option value="Tanaitic">Corpus: Tanaitic</option>
          <option value="Chasidut">Corpus: Chasidut</option>
          <option value="Musar">Corpus: Musar</option>
          <option value="Apocrypha">Corpus: Apocrypha</option>
          <option value="Modern Works">Corpus: Modern Works</option>
          <option value="Reference">Corpus: Reference</option>
          <option value="Other">Corpus: Other</option>
        </select>
        <label class="relevance-toggle"><input type="checkbox" class="wants-relevance"> Relevance</label>
      </section>

      <section class="results-panel">
        <div class="results-header">
          <div class="result-group-label" style="margin: 0;">Results</div>
          <button type="button" class="results-toggle-button" style="display:none;">Show results</button>
        </div>
        <div class="selected-result-summary" style="display:none;"></div>
        <div class="results-lists">
          <div class="result-group-label">Library matches</div>
          <ul class="result-list library-results"></ul>
          <div class="result-group-label">Search results</div>
          <ul class="result-list search-results"></ul>
          <p class="results-hint" aria-live="polite"></p>
        </div>
      </section>

      <section class="display-section">
        <div class="section-label">Display</div>
        <div class="mode-card-group" role="radiogroup" aria-label="Display mode">
          <button class="mode-card" data-mode="he" role="radio" aria-checked="false"><span>Source</span><span class="mode-card-indicator"></span></button>
          <button class="mode-card" data-mode="en" role="radio" aria-checked="false"><span>Translation</span><span class="mode-card-indicator"></span></button>
          <button class="mode-card" data-mode="both" role="radio" aria-checked="false"><span>Source with Translation</span><span class="mode-card-indicator"></span></button>
        </div>
      </section>

      <section class="layout-section bilingual-layout-wrapper">
        <div class="section-label">Layout</div>
        <div class="layout-option-group" role="radiogroup" aria-label="Bilingual layout">
          <button class="layout-option" data-layout="he-top" aria-label="Hebrew on top"><span class="layout-icon layout-icon-top" aria-hidden="true"></span></button>
          <button class="layout-option" data-layout="he-left" aria-label="Hebrew left"><span class="layout-icon layout-icon-left" aria-hidden="true"></span></button>
          <button class="layout-option" data-layout="he-right" aria-label="Hebrew right"><span class="layout-icon layout-icon-right" aria-hidden="true"></span></button>
        </div>
      </section>

      <section class="options-section">
        <div class="section-label">Options</div>
        <div class="options-panel">
          <div class="toggle-row hebrew-options-row">
            <label for="wants-vowels">Vowels</label>
            <input id="wants-vowels" type="checkbox" class="wants-vowels" checked>
          </div>
          <div class="toggle-row hebrew-options-row">
            <label for="wants-cantillation">Cantillation</label>
            <input id="wants-cantillation" type="checkbox" class="wants-cantillation" checked>
          </div>
          <div class="toggle-row pesukim-wrapper">
            <label for="wants-pesukim">Line markers</label>
            <input id="wants-pesukim" type="checkbox" class="wants-pesukim" checked>
          </div>
          <p class="helper-text pesukim-help">Applies to segmented refs (e.g., verse/line ranges).</p>
          <div class="toggle-row translation-details-row">
            <label for="include-translation-source-info">Translation details</label>
            <input id="include-translation-source-info" type="checkbox" class="include-translation-source-info">
          </div>
          <p class="helper-text translation-details-help">Adds version/source details below inserted text.</p>
          <div class="toggle-row">
            <label for="insert-sefaria-link">Insert Sefaria link</label>
            <input id="insert-sefaria-link" type="checkbox" class="insert-sefaria-link">
          </div>
        </div>
      </section>

      <section class="versions-section">
        <div class="section-label">Versions</div>
        <div class="versions-panel">
          <div class="version-control translation-version-control"></div>
          <details class="advanced-version-details">
            <summary>Source edition (advanced)</summary>
            <p class="advanced-version-note">Optional: choose a specific Hebrew/source edition only when needed.</p>
            <div class="version-control hebrew-version-control"></div>
            <p class="advanced-version-note"><a href="#" class="open-divine-name-preferences">Open divine name preferences</a></p>
          </details>
        </div>
      </section>

      <section class="preview-section">
        <div class="section-label">Preview</div>
        <div class="preview-panel">
          <section class="suggestions">
            <b>Please enter the title of a text or a source to insert.</b>
          </section>
        </div>
      </section>

      <button class="submit" id="insert-source" disabled>Insert</button>
      <button class="submit" id="open-on-sefaria" disabled style="margin-top:8px;">Open on Sefaria</button>

      <select class="output-mode-selection visually-hidden" aria-hidden="true">
        <option value="both" selected>Source with Translation</option>
        <option value="he">Source</option>
        <option value="en">Translation</option>
      </select>
      <select class="bilingual-layout-selection visually-hidden" aria-hidden="true">
        <option value="he-right" selected>Hebrew right</option>
        <option value="he-left">Hebrew left</option>
        <option value="he-top">Hebrew on top</option>
      </select>
    </main>

    <!--MAIN UX SCRIPT-->
    <script>//no need for $(document).ready() since this script is loaded at the end of the page
$(".input").attr("disabled", true);
var data = {};
google.script.run.withSuccessHandler(function (preferences) {
    if (preferences.include_translation_source_info == "true") {
        $('.include-translation-source-info').prop('checked', true);
    }
    $('.wants-vowels').prop('checked', preferences.nekudot !== "false");
    $('.wants-cantillation').prop('checked', preferences.teamim !== "false");
}).getPreferences();
$('.include-translation-source-info').on('change', function () {
    google.script.run.setPreferences({
        include_translation_source_info: $('.include-translation-source-info').is(':checked')
    });
});
google.script.run.withSuccessHandler(function (titles) {
    $(".input").removeAttr("disabled");
    $('.suggestions').html("<b>Please enter the title of a text or a source to insert.</b>");
    $('.input').autocomplete({
        source: function (request, response) {
            var matches = $.map(titles, function (tag) {
                if (tag.toUpperCase().indexOf(request.term.toUpperCase()) === 0) {
                    return tag;
                }
            });
            response(matches);
        },
        open: function () {
            $('.input').autocomplete("widget").width(280);
        }
    });
    var updatePesukimAvailability = function (response) {
        var supportsLineMarkers = !!(response && (Array.isArray(response.he) ||
            Array.isArray(response.text) ||
            response.lineMarkersAvailable === true));
        $('.pesukim-wrapper').toggle(supportsLineMarkers);
        $('.wants-pesukim').prop('disabled', !supportsLineMarkers);
        if (!supportsLineMarkers) {
            $('.wants-pesukim').prop('checked', false);
            $('.pesukim-help').text('Line markers are unavailable for this selection (single-block text).');
        }
        else {
            if (!$('.wants-pesukim').prop('checked')) {
                $('.wants-pesukim').prop('checked', true);
            }
            $('.pesukim-help').text('Applies to segmented refs (e.g., verse/line ranges).');
        }
    };
    var setInsertButtonState = function (enabled) {
        $('#insert-source').prop('disabled', !enabled);
    };
    var updateBilingualLayoutVisibility = function () {
        var outputMode = $('.output-mode-selection').val();
        $('.bilingual-layout-wrapper').toggle(outputMode === 'both');
    };
    var updateTranslationDetailsVisibility = function () {
        var outputMode = $('.output-mode-selection').val();
        $('.translation-details-row, .translation-details-help').toggle(outputMode === 'both' || outputMode === 'en');
    };
    var updateHebrewOptionsVisibility = function () {
        var outputMode = $('.output-mode-selection').val();
        $('.hebrew-options-row').toggle(outputMode !== 'en');
    };
    var updateVersionControlsVisibility = function () {
        var outputMode = $('.output-mode-selection').val();
